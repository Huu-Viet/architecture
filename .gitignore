# Node.js Dependencies
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
pnpm-lock.yaml
package-lock.json

# Build outputs
**/dist/
**/build/
**/out/
**/target/

# Environment files
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Logs
**/*.log

# Runtime data
**/pids
**/*.pid
**/*.seed

# Coverage directory used by tools like istanbul
**/coverage/
**/.nyc_output

# IDE and Editor files
**/.vscode/
**/.idea/
**/.DS_Store
**/Thumbs.db

# Java specific (for your Java projects)
**/*.class
**/bin/
**/.classpath
**/.project
**/.settings/

# Build tools
**/.gradle/
**/gradlew
**/gradlew.bat

# Temp directories
**/.tmp/
**/.temp/

# Docker files (optional, comment out if you want to keep)
# docker-compose.override.yml